<Window x:Class="ModForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:blazor="clr-namespace:Microsoft.AspNetCore.Components.WebView.Wpf;assembly=Microsoft.AspNetCore.Components.WebView.Wpf"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:ModForge"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:pages="clr-namespace:ModForge.UI.Pages;assembly=ModForge.UI"
        Title="ModForge"
        Width="1280"
        Height="720"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        WindowStyle="None"
        mc:Ignorable="d">

    <Border Padding="0"
            Background="#1E1E1E"
            BorderBrush="#333"
            BorderThickness="1"
            CornerRadius="8"
            SnapsToDevicePixels="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <!--  Custom Titlebar  -->
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  🧭 Titlebar  -->
            <Grid Grid.Row="0"
                  Background="Transparent"
                  MouseDown="TitleBar_MouseDown">
                <DockPanel>
                    <TextBlock Margin="15,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#c1c1c4"
                               Text="ModForge" />
                    <!--  Control Buttons  -->
                    <StackPanel Margin="0,0,14,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                        <Button Click="Minimize_Click"
                                Style="{StaticResource TitlebarButtonStyle}"
                                ToolTip="Minimieren">
                            ─
                        </Button>
                        <Button Click="MaximizeRestore_Click"
                                Style="{StaticResource TitlebarButtonStyle}"
                                ToolTip="Maximieren">
                            ☐
                        </Button>
                        <Button Click="Close_Click"
                                Style="{StaticResource CloseButtonStyle}"
                                ToolTip="Schließen">
                            ✕
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Grid>
            <blazor:BlazorWebView Grid.Row="1"
                                  HostPage="wwwroot/index.html"
                                  Services="{DynamicResource services}">
                <blazor:BlazorWebView.RootComponents>
                    <blazor:RootComponent ComponentType="{x:Type pages:App}"
                                          Selector="#app" />
                </blazor:BlazorWebView.RootComponents>
            </blazor:BlazorWebView>
        </Grid>
    </Border>
</Window>
